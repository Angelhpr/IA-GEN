APP_NAME=IA-GEN API
APP_VERSION=0.7.0-dev

GEMINI_API_KEY=YOUR_API_KEY
MODEL_NAME=gemini-3.5-flash

DEBUG=false
LOG_LEVEL=INFO

VECTOR_DB_PATH=data/vector_db

# Ingestion administrativa
# Permanece deshabilitada de forma predeterminada.
INGESTION_ENABLED=false

# Configura una clave larga y aleatoria solo cuando habilites la ingestion.
INGESTION_API_KEY=

# Ruta controlada por el servidor. No es recibida desde el cliente.
INGESTION_SOURCE_PATH=data/documentos

# Configuracion prevista para versiones futuras
DATABASE_URL=postgresql://user:password@localhost:5432/iagen
SECRET_KEY=CHANGE_ME